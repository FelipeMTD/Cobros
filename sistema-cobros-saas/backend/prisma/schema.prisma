// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏢 LA EMPRESA
model Tenant {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  plan          String     @default("FREE")
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  // Relaciones
  configuracion ConfiguracionEmpresa? // 🚨 NUEVO: Conexión con sus reglas
  users         User[]
  customers     Customer[]
  debts         Debt[]
}

// 👤 EL USUARIO
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

// 👥 EL CLIENTE
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  debts     Debt[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💰 EL COBRO / LA DEUDA
model Debt {
  id          String    @id @default(uuid())
  description String
  amount      Float
  status      String    @default("PENDING")
  dueDate     DateTime?
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ⚙️ EL MOTOR DE REGLAS FINANCIERAS (NUEVO)
model ConfiguracionEmpresa {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  
  // Reglas de negocio
  tasaInteres     Float    @default(20.0) // Ej: 20%
  limiteCreditos  Int      @default(2)    // Máximo de créditos por cliente
  cobrarMora      Boolean  @default(true) 
  excluirDomingos Boolean  @default(true) 
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}