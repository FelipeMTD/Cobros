// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏢 LA EMPRESA
model Tenant {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  plan          String     @default("FREE")
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  configuracion ConfiguracionEmpresa?
  users         User[]
  customers     Customer[]
  debts         Debt[]
  
  // 🚨 NUEVO: La gran bóveda de la empresa
  cajaGlobal    CajaGlobal? 
  cajasMenores  CajaMenor[]

  payments      Payment[]
}

// 👤 EL USUARIO (Admin o Cobrador)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  // 🚨 NUEVO: El cobrador tiene su propia billetera y su propia ruta de clientes
  cajaMenor CajaMenor?
  clientesAsignados Customer[]

  payments      Payment[]
}

// 👥 EL CLIENTE
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  // 🚨 NUEVO: Para el "Sistema de Rutas", el cliente se le asigna a un cobrador específico
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])

  debts     Debt[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💰 EL COBRO / LA DEUDA
model Debt {
  id          String    @id @default(uuid())
  description String
  amount      Float
  amountPaid  Float     @default(0) // 🚨 NUEVO: Cuánto ha abonado el cliente
  status      String    @default("PENDING")
  dueDate     DateTime?
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[] // 🚨 NUEVO: Historial de cuotas
}

// ⚙️ EL MOTOR DE REGLAS FINANCIERAS
model ConfiguracionEmpresa {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  
  tasaInteres     Float    @default(20.0) 
  limiteCreditos  Int      @default(2)    
  cobrarMora      Boolean  @default(true) 
  excluirDomingos Boolean  @default(true) 

  // 🚨 NUEVO: Configuración para excluir los lunes festivos (PRD 6.3)
  excluirFestivos Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// 🚨 TABLAS NUEVAS (MÓDULO FINANCIERO PRD 6.1)
// ==========================================

// 🏦 CAJA GLOBAL: El dinero central de la empresa en el banco/oficina
model CajaGlobal {
  id        String   @id @default(uuid())
  balance   Float    @default(0)
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  updatedAt DateTime @updatedAt
}

// 👝 CAJA MENOR: El dinero físico que el cobrador trae en el bolsillo
model CajaMenor {
  id        String   @id @default(uuid())
  balance   Float    @default(0)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  updatedAt DateTime @updatedAt
}

// 🧾 EL RECIBO DE PAGO (Historial de Cuotas)
model Payment {
  id          String   @id @default(uuid())
  amount      Float    // De cuánto fue la cuota
  debtId      String
  debt        Debt     @relation(fields: [debtId], references: [id])
  collectorId String
  collector   User     @relation(fields: [collectorId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
}