# --- SEGURIDAD (VITAL) ---
# Nunca subas tus contraseñas de base de datos o llaves secretas
.env
.env.local
.env.*.local

# --- NODE / BACKEND ---
# Evita subir gigas de librerías que se pueden reinstalar
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# --- PRISMA ---
# Ignora archivos temporales de migraciones si fuera necesario
/prisma/migrations-backup

# --- FLUTTER / MOBILE ---
# Archivos generados automáticamente por Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
# Archivos específicos de Android e iOS
android/**/generated/
android/app/debug/
android/app/release/
ios/Pods/
ios/.symlinks/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh

# --- EDITORES E IDEs ---
# Configuraciones personales de tu editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

venv/